{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leggende-napoletane.local/instagram/figma-map.schema.json",
  "title": "Figma Carousel Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "post_id",
    "status",
    "source_post",
    "asset_rules",
    "import_mode",
    "template_contract",
    "layout_rules",
    "slides",
    "figma"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "post_id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}-post-\\d{2}-[a-z0-9-]+$"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "in_progress", "ready_for_review", "approved", "done"]
    },
    "source_post": {
      "type": "string",
      "description": "Path del JSON in content_queue/."
    },
    "asset_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "size_px", "width", "height", "no_text_in_assets"],
      "properties": {
        "format": { "type": "string", "enum": ["jpg", "png"] },
        "size_px": { "type": "integer", "minimum": 1 },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "no_text_in_assets": { "type": "boolean" }
      }
    },
    "import_mode": {
      "type": "string",
      "enum": ["template_duplicate", "manual", "mixed"],
      "description": "Modalità prevista per trasferire il manifest in Figma."
    },
    "template_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["template_source", "required_layers"],
      "properties": {
        "template_source": { "type": "string" },
        "required_layers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["image", "fondino", "eyebrow", "title", "description", "source", "logo", "footer"]
          }
        }
      }
    },
    "layout_rules": {
      "type": "object",
      "additionalProperties": true,
      "required": ["format_px", "typography", "text_backdrop", "text_boxes", "logo"],
      "properties": {
        "format_px": {
          "type": "object",
          "additionalProperties": false,
          "required": ["width", "height"],
          "properties": {
            "width": { "type": "integer", "minimum": 1 },
            "height": { "type": "integer", "minimum": 1 }
          }
        },
        "typography": { "type": "object" },
        "text_backdrop": { "type": "object" },
        "text_boxes": { "type": "object" },
        "logo": { "type": "string" }
      }
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slide_number", "frame_name", "asset_path", "title", "copy", "visual_note", "figma_layers"],
        "properties": {
          "slide_number": { "type": "integer", "minimum": 1 },
          "frame_name": { "type": "string" },
          "asset_path": { "type": "string" },
          "title": { "type": "string" },
          "copy": { "type": "string" },
          "visual_note": { "type": "string" },
          "asset_origin": {
            "type": "string",
            "enum": ["generated", "supplied", "archive", "drive", "figma_only", "local", "unknown"]
          },
          "asset_status": {
            "type": "string",
            "enum": ["draft", "in_review", "approved", "in_figma", "rejected", "replaced"]
          },
          "rights": { "type": "string" },
          "qa_status": {
            "type": "string",
            "enum": ["pending", "passed", "needs_fix", "blocked", "superseded"]
          },
          "local_file_required": { "type": "boolean" },
          "figma_frame_id": { "type": "string" },
          "figma_bitmap_layer_id": { "type": "string" },
          "figma_layers": {
            "type": "object",
            "additionalProperties": false,
            "required": ["image", "fondino", "eyebrow", "title", "description", "source", "logo", "footer"],
            "properties": {
              "image": { "$ref": "#/$defs/figma_layer_ref" },
              "fondino": { "$ref": "#/$defs/figma_layer_ref" },
              "eyebrow": { "$ref": "#/$defs/figma_layer_ref" },
              "title": { "$ref": "#/$defs/figma_layer_ref" },
              "description": { "$ref": "#/$defs/figma_layer_ref" },
              "source": { "$ref": "#/$defs/figma_layer_ref" },
              "logo": { "$ref": "#/$defs/figma_layer_ref" },
              "footer": { "$ref": "#/$defs/figma_layer_ref" }
            }
          }
        }
      }
    },
    "figma": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file_url", "node_url"],
      "properties": {
        "file_url": { "type": "string" },
        "node_url": { "type": "string" }
      }
    },
    "qa": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "passed", "needs_fix", "blocked", "superseded"]
        },
        "checked_at": { "type": "string" },
        "checked_by": { "type": "string" },
        "local_contact_sheet": { "type": "string" },
        "figma_carousel_screenshot": { "type": "string" },
        "checked_frames": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 }
        },
        "open_issues": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": { "type": "string" }
      }
    }
  },
  "$defs": {
    "figma_layer_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "visible": { "type": "boolean" },
        "expected_text": { "type": "string" },
        "locked": { "type": "boolean" },
        "font_family": { "type": "string" },
        "font_size": { "type": "number" },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number" },
        "height": { "type": "number" },
        "notes": { "type": "string" }
      }
    }
  }
}
