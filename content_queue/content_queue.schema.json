{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leggende-napoletane.local/instagram/content_queue.schema.json",
  "title": "Instagram Content Queue Item",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "post_id",
    "status",
    "priority",
    "topic",
    "angle",
    "target",
    "editorial_owner",
    "sources",
    "claims",
    "cover",
    "slides",
    "caption",
    "design_notes",
    "production_preflight",
    "figma",
    "fact_check",
    "approvals",
    "publication",
    "performance",
    "blocked"
  ],
  "properties": {
    "post_id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}-post-\\d{2}-[a-z0-9-]+$",
      "description": "Identificatore stabile, per esempio 2026-07-02-post-01-tema."
    },
    "status": {
      "type": "string",
      "enum": [
        "idea",
        "brief_ready",
        "draft_ready",
        "fact_check_needed",
        "fact_checked",
        "design_ready",
        "figma_done",
        "approved",
        "scheduled",
        "published",
        "archived"
      ]
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "urgent"]
    },
    "topic": { "type": "string", "minLength": 3 },
    "angle": { "type": "string", "minLength": 3 },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["audience", "goal", "format"],
      "properties": {
        "audience": { "type": "string", "minLength": 1 },
        "goal": { "type": "string", "minLength": 1 },
        "format": { "type": "string", "enum": ["carousel", "single_card", "reel", "story"] }
      }
    },
    "editorial_owner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["editor", "journalist", "fact_checker", "designer"],
      "properties": {
        "editor": { "type": "string" },
        "journalist": { "type": "string" },
        "fact_checker": { "type": "string" },
        "designer": { "type": "string" }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_id", "title", "type", "status", "url", "checked_at"],
        "properties": {
          "source_id": { "type": "string", "pattern": "^src-[0-9]{3}$" },
          "title": { "type": "string", "minLength": 3 },
          "type": {
            "type": "string",
            "enum": ["primary", "secondary", "archive", "oral_tradition", "field_note", "internal", "placeholder"]
          },
          "url": { "type": "string" },
          "author": { "type": "string" },
          "published_at": { "type": "string" },
          "checked_at": { "type": "string" },
          "status": { "type": "string", "enum": ["to_verify", "verified", "rejected", "placeholder"] },
          "supports": { "type": "string" },
          "caveat": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim_id", "text", "source_ids", "evidence", "caveat", "status"],
        "properties": {
          "claim_id": { "type": "string", "pattern": "^claim-[0-9]{3}$" },
          "text": { "type": "string", "minLength": 3 },
          "source_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^src-[0-9]{3}$" }
          },
          "evidence": { "type": "string" },
          "caveat": { "type": "string" },
          "status": { "type": "string", "enum": ["to_verify", "verified", "rejected", "needs_context"] },
          "notes": { "type": "string" }
        }
      }
    },
    "cover": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headline", "subheadline", "visual_idea"],
      "properties": {
        "headline": { "type": "string" },
        "subheadline": { "type": "string" },
        "visual_idea": { "type": "string" }
      }
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slide_number", "role", "title", "copy", "visual_note", "source_ids"],
        "properties": {
          "slide_number": { "type": "integer", "minimum": 1 },
          "role": { "type": "string", "enum": ["cover", "body", "closing"] },
          "title": { "type": "string" },
          "copy": { "type": "string" },
          "visual_note": { "type": "string" },
          "source_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^src-[0-9]{3}$" }
          }
        }
      }
    },
    "caption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "cta", "source_note"],
      "properties": {
        "text": { "type": "string" },
        "cta": { "type": "string" },
        "source_note": { "type": "string" }
      }
    },
    "design_notes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["style_direction", "safe_area", "asset_rules", "risks"],
      "properties": {
        "style_direction": { "type": "string" },
        "safe_area": { "type": "string" },
        "asset_rules": { "type": "array", "items": { "type": "string" } },
        "risks": { "type": "array", "items": { "type": "string" } }
      }
    },
    "production_preflight": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "checked_at", "asset_format", "asset_count", "checks", "notes"],
      "properties": {
        "status": { "type": "string", "enum": ["not_started", "passed", "needs_fix"] },
        "checked_at": { "type": "string" },
        "asset_format": { "type": "string", "enum": ["1080x1350", "1080x1080", "1080x1920", "custom"] },
        "asset_count": { "type": "integer", "minimum": 0 },
        "checks": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "cover_approved",
            "manifest_matches_slides",
            "assets_named_and_sized",
            "assets_have_no_text_logo_sources",
            "copy_line_budget_ok",
            "figma_template_layers_ready",
            "figma_qa_sample_done"
          ],
          "properties": {
            "cover_approved": { "type": "boolean" },
            "manifest_matches_slides": { "type": "boolean" },
            "assets_named_and_sized": { "type": "boolean" },
            "assets_have_no_text_logo_sources": { "type": "boolean" },
            "copy_line_budget_ok": { "type": "boolean" },
            "figma_template_layers_ready": { "type": "boolean" },
            "figma_qa_sample_done": { "type": "boolean" }
          }
        },
        "notes": { "type": "string" }
      }
    },
    "figma": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "file_url", "node_url", "manifest_path"],
      "properties": {
        "status": { "type": "string", "enum": ["not_started", "in_progress", "done", "needs_review"] },
        "file_url": { "type": "string" },
        "node_url": { "type": "string" },
        "manifest_path": { "type": "string" }
      }
    },
    "fact_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "checked_by", "checked_at", "summary", "open_issues"],
      "properties": {
        "status": { "type": "string", "enum": ["not_started", "needed", "passed", "failed", "needs_review"] },
        "checked_by": { "type": "string" },
        "checked_at": { "type": "string" },
        "summary": { "type": "string" },
        "open_issues": { "type": "array", "items": { "type": "string" } }
      }
    },
    "approvals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["editorial", "fact_check", "cover", "design", "final"],
      "properties": {
        "editorial": { "$ref": "#/$defs/approval" },
        "fact_check": { "$ref": "#/$defs/approval" },
        "cover": { "$ref": "#/$defs/approval" },
        "design": { "$ref": "#/$defs/approval" },
        "final": { "$ref": "#/$defs/approval" }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "scheduled_at", "published_at", "published_url"],
      "properties": {
        "status": { "type": "string", "enum": ["not_scheduled", "scheduled", "published", "archived"] },
        "scheduled_at": { "type": "string" },
        "published_at": { "type": "string" },
        "published_url": { "type": "string" }
      }
    },
    "performance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "metrics", "observations", "recommendations"],
      "properties": {
        "status": { "type": "string", "enum": ["not_available", "pending", "reviewed"] },
        "metrics": {
          "type": "object",
          "additionalProperties": { "type": ["number", "string", "null"] }
        },
        "observations": { "type": "array", "items": { "type": "string" } },
        "recommendations": { "type": "array", "items": { "type": "string" } }
      }
    },
    "blocked": {
      "type": "object",
      "additionalProperties": false,
      "required": ["is_blocked", "blocked_by_role", "reason", "next_action"],
      "properties": {
        "is_blocked": { "type": "boolean" },
        "blocked_by_role": { "type": "string" },
        "reason": { "type": "string" },
        "next_action": { "type": "string" }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "fact_checked" } } },
      "then": {
        "properties": {
          "fact_check": {
            "properties": {
              "status": { "const": "passed" }
            }
          },
          "approvals": {
            "properties": {
              "fact_check": {
                "properties": {
                  "status": { "const": "approved" }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "status": { "const": "design_ready" } } },
      "then": {
        "properties": {
          "fact_check": {
            "properties": {
              "status": { "const": "passed" }
            }
          },
          "approvals": {
            "properties": {
              "editorial": {
                "properties": {
                  "status": { "const": "approved" }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "status": { "const": "figma_done" } } },
      "then": {
        "properties": {
          "figma": {
            "properties": {
              "status": { "const": "done" }
            }
          },
          "approvals": {
            "properties": {
              "cover": {
                "properties": {
                  "status": { "const": "approved" }
                }
              }
            }
          },
          "production_preflight": {
            "properties": {
              "status": { "const": "passed" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "status": { "const": "approved" } } },
      "then": {
        "properties": {
          "approvals": {
            "properties": {
              "design": {
                "properties": {
                  "status": { "const": "approved" }
                }
              },
              "final": {
                "properties": {
                  "status": { "const": "approved" }
                }
              }
            }
          },
          "figma": {
            "properties": {
              "status": { "const": "done" }
            }
          },
          "production_preflight": {
            "properties": {
              "status": { "const": "passed" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "status": { "const": "scheduled" } } },
      "then": {
        "properties": {
          "publication": {
            "properties": {
              "status": { "const": "scheduled" },
              "scheduled_at": { "type": "string", "minLength": 1 }
            }
          },
          "approvals": {
            "properties": {
              "design": {
                "properties": {
                  "status": { "const": "approved" }
                }
              },
              "final": {
                "properties": {
                  "status": { "const": "approved" }
                }
              }
            }
          },
          "figma": {
            "properties": {
              "status": { "const": "done" }
            }
          },
          "production_preflight": {
            "properties": {
              "status": { "const": "passed" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "status": { "const": "published" } } },
      "then": {
        "properties": {
          "publication": {
            "properties": {
              "status": { "const": "published" },
              "scheduled_at": { "type": "string", "minLength": 1 },
              "published_at": { "type": "string", "minLength": 1 },
              "published_url": { "type": "string", "minLength": 1 }
            }
          },
          "approvals": {
            "properties": {
              "design": {
                "properties": {
                  "status": { "const": "approved" }
                }
              },
              "final": {
                "properties": {
                  "status": { "const": "approved" }
                }
              }
            }
          },
          "figma": {
            "properties": {
              "status": { "const": "done" }
            }
          },
          "production_preflight": {
            "properties": {
              "status": { "const": "passed" }
            }
          },
          "sources": {
            "not": {
              "contains": {
                "properties": {
                  "type": { "const": "placeholder" }
                }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "by", "at", "notes"],
      "properties": {
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "needs_changes"] },
        "by": { "type": "string" },
        "at": { "type": "string" },
        "notes": { "type": "string" }
      }
    }
  }
}
